{
    "compilerOptions": {
      "module": "commonjs",
      "declaration": true,
      "removeComments": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "allowSyntheticDefaultImports": true,
      "target": "ES2020",
      "sourceMap": true,
      "outDir": "./dist",
      "baseUrl": "./",
      "paths": {
        "@auth-service/*": ["src/*"]
      },
      "incremental": true,
      "strict": true,
      "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "src/**/*.spec.ts"],
    "exclude": ["node_modules", "dist"]
  }
  